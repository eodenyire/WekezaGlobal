# ============================================================
#  WekezaGlobal Infrastructure (WGI) — Environment Variables
#  Copy this file to .env and fill in all required values.
#  Never commit .env to source control.
# ============================================================

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development                          # development | production | test
PORT=3001                                     # Backend API port

# ─── PostgreSQL (Primary Database) ───────────────────────────────────────────
DATABASE_URL=postgresql://wgi_user:wgi_pass@localhost:5432/wgi_db
POSTGRES_DB=wgi_db
POSTGRES_USER=wgi_user
POSTGRES_PASSWORD=wgi_pass                    # CHANGE in production

# ─── MySQL (Analytics / Reporting Database) ──────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=wgi_analytics
MYSQL_USER=wgi_analytics_user
MYSQL_PASSWORD=wgi_analytics_pass             # CHANGE in production
MYSQL_ROOT_PASSWORD=wgi_root_pass             # CHANGE in production
# Optional: full connection string (takes precedence over above fields)
# MYSQL_URL=mysql://wgi_analytics_user:wgi_analytics_pass@localhost:3306/wgi_analytics
MYSQL_ANALYTICS_PASSWORD=wgi_analytics_pass   # Used by docker-compose healthcheck

# ─── Redis (Cache / Session Store) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Optionally set a password for Redis in production:
# REDIS_PASSWORD=your-redis-password

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-super-secret-key   # REQUIRED — min 32 chars
JWT_EXPIRY=3600                               # Token lifetime in seconds (1 hour)

# ─── OAuth2 (Client Credentials Flow) ────────────────────────────────────────
OAUTH_CLIENT_ID=wgi-client
OAUTH_CLIENT_SECRET=wgi-client-secret         # CHANGE in production

# ─── Webhook Security ─────────────────────────────────────────────────────────
SETTLEMENT_WEBHOOK_SECRET=change-me-in-production-webhook-secret   # REQUIRED

# ─── Sandbox / v1-core ────────────────────────────────────────────────────────
SANDBOX_ENABLED=true                          # Enable sandbox API endpoints
SANDBOX_BASE_URL=http://localhost:3001/v1/sandbox

# ─── Wekeza v1-Core Banking System Integration ────────────────────────────────
# WekezaGlobal acts as an API gateway between external developers (fintech
# partners) and the Wekeza core banking system (github.com/eodenyire/Wekeza).
#
# When WEKEZA_CORE_ENABLED=false, live /v1/core-banking/* routes return 503 and
# developers are directed to the sandbox (/v1/sandbox/core-banking/*).
#
WEKEZA_CORE_URL=http://localhost:5001         # Base URL of Wekeza v1-Core .NET API
WEKEZA_CORE_ENABLED=false                     # Set to 'true' when v1-Core is running
WEKEZA_CORE_SERVICE_USER=wgi-gateway          # Service account username in v1-Core
WEKEZA_CORE_SERVICE_PASS=change-me-in-prod    # CHANGE — service account password
WEKEZA_CORE_TOKEN_TTL=3000                    # Seconds before cached service token refreshes
WEKEZA_CORE_TIMEOUT_MS=10000                  # HTTP timeout for v1-Core requests (ms)

# ─── External Payment Integrations ───────────────────────────────────────────

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox                           # sandbox | live

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_MODE=test                              # test | live

# Wise (TransferWise)
WISE_API_KEY=your-wise-api-key
WISE_PROFILE_ID=your-wise-profile-id
WISE_MODE=sandbox                             # sandbox | live

# ─── Monitoring & Observability ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin                  # CHANGE in production

# ─── Email (Transactional) ────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false                             # true for port 465
SMTP_USER=no-reply@wekeza.io
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM="WekezaGlobal <no-reply@wekeza.io>"

# ─── SMS / OTP ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── KYC / Identity Verification ─────────────────────────────────────────────
KYC_PROVIDER=onfido                           # onfido | jumio | manual
ONFIDO_API_TOKEN=your-onfido-api-token

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=3600000                  # 1 hour in milliseconds
RATE_LIMIT_MAX_REQUESTS=1000                  # Max requests per window per API key

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                                # error | warn | info | debug
LOG_FORMAT=json                               # json | pretty

# ─── ELK Stack (optional — activate with --profile logging) ──────────────────
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000             # Frontend origin(s); comma-separated in prod

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_CREDIT_SCORING=true
FEATURE_CARD_ISSUANCE=true
FEATURE_FX_AUTO_HEDGE=false
